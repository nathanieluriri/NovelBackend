# ============================================================================
# mei-next environment variables
# ----------------------------------------------------------------------------
# This file sits at the Vercel "Root Directory" (mei-next). Copy these into
# Vercel -> Project -> Settings -> Environment Variables. Never commit a real .env.
#
# Legend:
#   [REQUIRED] the app will not work without it
#   [FEATURE]  only needed if you use that feature
#   (no tag)   has a safe default; override only if you need to
# ============================================================================

# --- Database --------------------------------------------------------------
MONGO_URL=                      # [REQUIRED] e.g. mongodb+srv://user:pass@cluster/...
DB_NAME=                        # [REQUIRED] database name, e.g. mei

# --- Redis / Upstash (OTP store + entity-summary cache) --------------------
# Create an Upstash Redis database, then copy its REST URL + token.
UPSTASH_REDIS_REST_URL=         # [REQUIRED] https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=       # [REQUIRED]

# --- Auth / JWT ------------------------------------------------------------
# SECRETID is NOT a plain secret. It is the Mongo ObjectId of a document in the
# `secret_keys` collection whose fields are { "<keyId>": "<hmacSecret>", ... }.
# JWTs are signed with a random key from that document. You MUST create that doc
# (see NOTE 1 below) or all auth/JWT will fail.
SECRETID=                       # [REQUIRED] 24-hex ObjectId of the secret_keys doc

# --- Email / Resend (OTP, admin invites, password-reset emails) ------------
RESEND_API_KEY=                 # [FEATURE] re_... ; without it OTP/admin/reset emails never send
EMAIL_FROM_DOMAIN=mie.app       # verified Resend sending domain (default: mie.app)

# --- Google OAuth (only if you offer Google sign-in) -----------------------
GOOGLE_CLIENT_ID=               # [FEATURE]
GOOGLE_CLIENT_SECRET=           # [FEATURE]
GOOGLE_OAUTH_CALLBACK_URL=https://<your-vercel-domain>/api/v2/user/google/callback
GOOGLE_OAUTH_REDIRECT_TARGETS={"prod":{"success":"https://<frontend>/portal/auth/success","error":"https://<frontend>/portal/auth/error"}}
GOOGLE_OAUTH_DEFAULT_TARGET=prod
GOOGLE_OAUTH_EXCHANGE_TTL_SECONDS=120
OAUTH_STRICT_STATE=false        # true = require the per-flow login-CSRF cookie (may break dropped-cookie logins)

# --- Payments (set only the providers you actually use) --------------------
STRIPE_SECRET_KEY=              # [FEATURE]
STRIPE_WEBHOOK_SECRET=          # [FEATURE]
STRIPE_ENABLED=true
PAYSTACK_SECRET_KEY=            # [FEATURE]
PAYSTACK_WEBHOOK_SECRET=        # [FEATURE]
PAYSTACK_ENABLED=true
FLUTTERWAVE_SECRET_KEY=         # [FEATURE]
FLW_WEBHOOK_SECRET_HASH=        # [FEATURE]
PAYMENTS_PROVIDER_TIMEOUT_SECONDS=10
PAYMENTS_ORCHESTRATOR_ENABLED=true
ENTITLEMENTS_WRITE_ENABLED=true

# --- Optional --------------------------------------------------------------
LOCATION_API=                   # ipinfo.io token; geo enrichment for the new-IP security email
DEFAULT_ADMIN_EMAIL=            # used by scripts/seed-default-admin.ts (first allowed admin)
EMAIL_USERNAME=                 # used by scripts/seed-default-admin.ts (the "invited by" address)

# ============================================================================
# NOTES (things env values alone do not set up)
#
# 1. secret_keys document (required for auth):
#      In Mongo, insert ONE document into the `secret_keys` collection, e.g.
#        { "k1": "<a long random hmac secret>" }
#      then set SECRETID to that document's _id (24-hex). Without it, sign-in,
#      tokens, and every authenticated route fail.
#
# 2. One-off setup scripts (run once against the production database):
#        npx tsx scripts/ensure-indexes.ts       # create all MongoDB indexes
#        npx tsx scripts/seed-default-admin.ts    # seed the default allowed admin
#
# 3. CORS: this backend does not currently send CORS headers. If the frontend
#    is served from a different origin than this API, browser requests will be
#    blocked until CORS is added (a Next.js middleware). Same-origin and
#    server-to-server calls are unaffected.
#
# 4. Payment webhooks: after deploying, point each provider's dashboard at
#        https://<your-vercel-domain>/api/v2/payment/webhooks/flutterwave
#        https://<your-vercel-domain>/api/v2/payment/webhooks/paystack
#        https://<your-vercel-domain>/api/v2/payment/webhooks/stripe
#
# 5. Google OAuth: add the exact GOOGLE_OAUTH_CALLBACK_URL above to your Google
#    Cloud OAuth client's "Authorized redirect URIs".
# ============================================================================
