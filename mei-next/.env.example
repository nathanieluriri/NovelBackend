MONGO_URL=
DB_NAME=
SECRETID=
SESSION_SECRET_KEY=
SESSION_COOKIE_NAME=mei_session
SESSION_COOKIE_SAME_SITE=none
SESSION_COOKIE_HTTPS_ONLY=true
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_MAX_AGE=900
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=https://<backend>/api/v2/user/google/callback
GOOGLE_OAUTH_REDIRECT_TARGETS={"dev":{"success":"https://sandbox-mei.vercel.app/portal/auth/success","error":"https://sandbox-mei.vercel.app/portal/auth/error"}}
GOOGLE_OAUTH_DEFAULT_TARGET=dev
GOOGLE_OAUTH_EXCHANGE_TTL_SECONDS=120
# OAUTH_STRICT_STATE=true makes the per-flow oauth_state cookie MANDATORY (full
# login-CSRF binding). Default (unset/false) preserves legacy behavior: complete
# login even if the cookie is dropped, rejecting only a positively-mismatched cookie.
OAUTH_STRICT_STATE=false
CORS_ALLOWED_ORIGINS=["http://localhost:3001","https://sandbox-mei.vercel.app"]
RESEND_API_KEY=
LOCATION_API=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_ENABLED=true
FLUTTERWAVE_SECRET_KEY=
FLW_WEBHOOK_SECRET_HASH=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
PAYSTACK_ENABLED=true
PAYMENTS_PROVIDER_TIMEOUT_SECONDS=10
PAYMENTS_ORCHESTRATOR_ENABLED=true
ENTITLEMENTS_WRITE_ENABLED=true
DEFAULT_ADMIN_EMAIL=
