# Google Cloud OAuth client settings for this backend:
# Authorized JavaScript origin: https://meibackend.affiliatemarketing.com.ng
# Authorized redirect URI: https://meibackend.affiliatemarketing.com.ng/api/v1/user/google/callback
# Frontend redirect targets are backend-managed handoff destinations:
# local  -> success: http://localhost:3001/portal/auth/success
# local  -> error:   http://localhost:3001/portal/auth/error
# dev    -> success: https://sandbox-mei.vercel.app/portal/auth/success
# dev    -> error:   https://sandbox-mei.vercel.app/portal/auth/error
# prod/mobile should be replaced with your real production frontend and app deep links.
# Google Cloud does NOT need the frontend success/error URLs above.
# Google still only needs the backend redirect URI listed above.
# Frontend initiation examples:
# local: window.location.assign("https://meibackend.affiliatemarketing.com.ng/api/v1/user/google/auth?target=local")
# dev:   window.location.assign("https://meibackend.affiliatemarketing.com.ng/api/v1/user/google/auth?target=dev")
# Do not start /api/v1/user/google/auth with fetch/axios.
# The browser must keep the backend session cookie for the Google callback state check.
